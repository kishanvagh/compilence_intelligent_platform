FROM node:20-alpine

WORKDIR /app

# Install system dependencies for PDF processing
RUN apk add --no-cache \
    poppler-utils \
    tesseract-ocr \
    tesseract-ocr-eng \
    fontconfig \
    msttcorefonts-installer \
  && update-ms-fonts

COPY backend/package*.json ./
RUN npm ci --only=production

COPY backend/ .
RUN mkdir -p logs uploads

EXPOSE 5000

CMD ["node", "src/server.js"]